ID = electron_gas
NameKey = "Resource/ElectronGas"
PluralNameKey = "Resource/ElectronGasPlural"
DescriptionKey = "Resource/ElectronGasDesc"
BuyPrice = 150
MaxPerNugget = 1
MaxStackSize = 5
FlexGridPriorityKey = "flex_grid_electron_gas"
FlexGridDefaultPriority = 1
DropRates = &<./Data/resources/resources.rules>/CommonMaterialDropRates

Icon
{
	Texture
	{
		File = "icon.png"
		MipLevels = max
	}
	Size = [64, 64]
}

Overlay
{
	Texture
	{
		File = "overlay.png"
		SampleMode = Linear
		MipLevels = max
	}
	Size = [1, 1]
}

DeathHitEffects // Scaled with stack size.
[
	{
		Type = ExplosiveDamage
		TotalDamage = { BaseValue = 2000; EffectScaleExponent = 1 }
		Radius = 3
		Delay = .05
//		StatusType = cosmoteer.fire
//		StatusChancePerNDamage = 50%
//		StatusValue = 1
//		StatusValueType = Interpolated
//		NDamage = 1000
		CrewKillChance = 5%
		Filter
		{
			OperationalHealth = true
			StructuralHealth = false
			Friendlies = true
		}
	}
	{
		Type = ExplosiveDamage
		TotalDamage = { BaseValue = 1000; EffectScaleExponent = 1 }
		Radius = 3
		Delay = .05
		Filter
		{
			OperationalHealth = false
			StructuralHealth = true
			Friendlies = true
			Crew = false
		}
	}
	{
		Type = ExplosiveResourceDrain
		ResourceType = battery
		Radius = 3
		TotalDrain = { BaseValue = 4000; EffectScaleExponent = 1 }
		Slices = 1
		Filter
		{
			Ships = true
			Shields = true
			Friendlies = true
		}
		MediaEffectsOnDrainFactor = .0005
		MediaEffectsOnDrain
		[
			&<./Data/shots/missile_emp/particles/missile_emp_hit_sizzle.rules>
			&<./Data/shots/missile_emp/particles/missile_emp_lightning.rules>
			&<./Data/shots/missile_emp/particles/missile_emp_drain.rules>
			
			: /BASE_SOUNDS/AudioExterior
			{
				RandomSounds = ["./Data/shots/disruptor_bolt/sounds/disruptor_discharge_01.wav",
								"./Data/shots/disruptor_bolt/sounds/disruptor_discharge_02.wav",
								"./Data/shots/disruptor_bolt/sounds/disruptor_discharge_03.wav",
								"./Data/shots/disruptor_bolt/sounds/disruptor_discharge_04.wav"]
				Volume = 1
				SpeedVariation = .2
			}
		]
	}
]
HitResponse
{
	HitEffects = &~/DeathHitEffects
	MediaEffects = &~/DeathMediaEffects
	Chance = 0
	ChancePerNDamage = 0
	RequireDirectHit = true
	DamageTypeOverrides
	{
		fire
		{
			ChancePerNDamage = 1%
			NDamage = &<./Data/statuses/fire/fire.rules>/DAMAGE_PER_TICK
		}
	}
}
DeathMediaEffects = &/COMMON_EFFECTS/MedPartDestroyed
NuggetSprite
{
	File = "electron_gas.png"
	NormalsFile = "electron_gas_normals.png"
	Size = [1, 1]
	Offset = [.25+4/64, 0]
	UVRotation = 1
}

