ID = dilithium
NameKey = "Resource/Dilithium"
PluralNameKey = "Resource/DilithiumPlural"
DescriptionKey = "Resource/DilithiumDesc"
BuyPrice = 100
AsteroidDensity = 0.04//gold is 0.08 @500credits
MaxPerNugget = 1
MaxStackSize = 5
FlexGridPriorityKey = "flex_grid_diamond"
FlexGridDefaultPriority = 1
DropRates = &<./Data/resources/resources.rules>/RareMaterialDropRates
Rarity = RawRare

Icon
{
	Texture
	{
		File = "icon.png"
		MipLevels = max
	}
	Size = [64, 64]
}

Overlay
{
	Texture
	{
		File = "overlay.png"
		SampleMode = Linear
		MipLevels = max
	}
	Size = [1, 1]
}

DeathHitEffects // Scaled with stack size.
[
	{
		Type = ExplosiveDamage
		TotalDamage = 8000
		Radius = 14
		Delay = .05
		StatusType = cosmoteer.fire
		StatusChancePerNDamage = 50%
		StatusValue = 1
		StatusValueType = Interpolated
		NDamage = 1000
		CrewKillChance = 30%
		Filter
		{
			OperationalHealth = true
			StructuralHealth = false
			Friendlies = true
		}
	}
	{
		Type = ExplosiveDamage
		TotalDamage = 6000
		Radius = 7
		Delay = .05
		Filter
		{
			OperationalHealth = false
			StructuralHealth = true
			Friendlies = true
			Crew = false
		}
	}
]
HitResponse
{
	HitEffects = &~/DeathHitEffects
	MediaEffects = &~/DeathMediaEffects
	Chance = 0
	ChancePerNDamage = 0
	RequireDirectHit = true
	DamageTypeOverrides
	{
		fire
		{
			ChancePerNDamage = 2.5%
			NDamage = &<./Data/statuses/fire/fire.rules>/DAMAGE_PER_TICK
		}
	}
}
DeathMediaEffects = &/COMMON_EFFECTS/MedPartDestroyed
NuggetSprite
{
	File = "dilithium.png"
	NormalsFile = "dilithium_normals.png"
	Size = [1, 1]
	Offset = [.25+4/64, 0]
	UVRotation = 1
}

StackSprites
