ID = antimatter
NameKey = "Resource/Antimatter"
PluralNameKey = "Resource/AntimatterPlural"
DescriptionKey = "Resource/AntimatterDesc"
BuyPrice = 200
MaxPerNugget = 1
MaxStackSize = 5
FlexGridPriorityKey = "flex_grid_antimatter"
FlexGridDefaultPriority = 1
DropRates = &<./Data/resources/resources.rules>/RareMaterialDropRates

Icon
{
	Texture
	{
		File = "icon.png"
		MipLevels = max
	}
	Size = [64, 64]
}

Overlay
{
	Texture
	{
		File = "overlay.png"
		SampleMode = Linear
		MipLevels = max
	}
	Size = [1, 1]
}

DeathHitEffects // Scaled with stack size.
[
	{
		Type = ExplosiveDamage
		TotalDamage = { BaseValue = 8000; EffectScaleExponent = 1 }
		Radius = 14
		Delay = .05
		StatusType = cosmoteer.fire
		StatusChancePerNDamage = 50%
		StatusValue = 1
		StatusValueType = Interpolated
		NDamage = 1000
		CrewKillChance = 30%
		Filter
		{
			OperationalHealth = true
			StructuralHealth = false
			Friendlies = true
		}
	}
	{
		Type = ExplosiveDamage
		TotalDamage = { BaseValue = 8000; EffectScaleExponent = 1 }
		Radius = 7
		Delay = .05
		Filter
		{
			OperationalHealth = false
			StructuralHealth = true
			Friendlies = true
			Crew = false
		}
	}
]
HitResponse
{
	HitEffects = &~/DeathHitEffects
	MediaEffects = &~/DeathMediaEffects
	Chance = 0
	ChancePerNDamage = 0
	RequireDirectHit = true
	DamageTypeOverrides
	{
		fire
		{
			ChancePerNDamage = 2.5%
			NDamage = &<./Data/statuses/fire/fire.rules>/DAMAGE_PER_TICK
		}
	}
}
DeathMediaEffects = &/COMMON_EFFECTS/MedPartDestroyed
NuggetSprite
{
	File = "antimatter.png"
	NormalsFile = "antimatter_normals.png"
	Size = [1, 1]
	Offset = [.25+4/64, 0]
	UVRotation = 1
}

StackSprites
[
	{
		File = "antimatter_stack_1.png"
		Size = [1, 1]
	}
	{
		File = "antimatter_stack_2.png"
		Size = [1, 1]
	}
	{
		File = "antimatter_stack_3.png"
		Size = [1, 1]
	}
	{
		File = "antimatter_stack_4.png"
		Size = [1, 1]
	}
	{
		File = "antimatter_stack_5.png"
		Size = [1, 1]
	}
]

StackReceiveMediaEffects
[
	: /BASE_SOUNDS/AudioInterior
	{
		Sound = "antimatter_deliver.wav"
		Volume = 1.0
		Speed = 1.2
		SpeedVariation = .05
	}
]

StackPickupMediaEffects = &/COMMON_EFFECTS/PartPickup
NuggetPickupMediaEffects = &/COMMON_EFFECTS/NuggetPickup
