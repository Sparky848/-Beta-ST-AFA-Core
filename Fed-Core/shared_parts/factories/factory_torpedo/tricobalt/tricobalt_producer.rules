ResourceConverter
{
	Type = ResourceConverter
	OperationalToggle = IsOperational
	From
	[
		{
			Storage = AntimatterSplitter
			Quantity = 6
		}
		{
			Storage = BatteryStorage
			Quantity = 500
			MinQuantityForConversion = 1
		}
	]
	ToStorage = TricobaltTorpedoPartStorage
	ToQuantity = 1
	Interval = { BaseValue=.65; BuffType=Factory; BuffMode=Divide; }//one antimatter and 6.5 batteries lasts 9.75 seconds and nets 13.3333... parts
}
TricobaltTorpedoPartStorage
{
	Type = TypedResourceGrid
	ResourceType = tricobalt_torpedo_part
	GridRect = [0, 2, 2, 1]
	Layer = "doodads_low"
	SpriteInset = [8/64, 3/64, 8/64, 12/64]
	SuppliesResources = true
	SupplyToggleButtonOffset = [0, -.4]
	ToggleOnResources = &../ResourceConverter/From/0/Quantity
	ToggleOffResources = (&ToggleOnResources) - 1
	RandomSpriteRotation = true
	InitToMaxResources = 0
}
ConvertEffects
{
	Type = TriggeredEffects
	Trigger = ResourceConverter
	Location = [1, 1.5]
	MediaEffects
	[
		: /BASE_SOUNDS/AudioInterior
		{
			RandomSounds = ["./Data/ships/terran/factory_he/sounds/missile_factory_putdown_01.wav",
							"./Data/ships/terran/factory_he/sounds/missile_factory_putdown_02.wav",
							"./Data/ships/terran/factory_he/sounds/missile_factory_putdown_03.wav",
							"./Data/ships/terran/factory_he/sounds/missile_factory_putdown_04.wav",
							"./Data/ships/terran/factory_he/sounds/missile_factory_putdown_05.wav"]
			Volume = 1
			Db = -2
			Speed = 1
			SpeedVariation = .05
		}
	]
}
