			FromStorage = BatteryStorage
			ToStorage = CloudyGasStorage
			FromQuantity = 4000
			ToQuantity = 4
			//Delay = 5
			CheckResourceLimits = true
			OnlyUpdateToggleOnTrigger = true
		}
