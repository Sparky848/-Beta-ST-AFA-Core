	{
		Action = AddMany
		AddTo = "<resources/resources.rules>/Resources"
		ManyToAdd = &<resources/resources.rules>/Resources
	}
	{
		Action = AddMany
		AddTo = "<doodads/doodads.rules>/Doodads"
		ManyToAdd = &<doodads/doodads.rules>/Doodads
	}
//	{
//		Action = AddMany
//		AddTo = "<modes/career/career.rules>/TradeRoutes/StationResourceTradeDeltas"
//		ManyToAdd
//		[
//			{ ResourceType=antimatter;  		DesiredDelta=[-10, 10]; }
//			{ ResourceType=dilithium; 			DesiredDelta=[-10, 10]; }
//			{ ResourceType=torpedo_part;        DesiredDelta=[-25, 25]; }
//		]
//	}
	{
		Action = AddMany
		AddTo = "<modes/career/career.rules>/BaseTradeShip/ResourcesCarried"
		ManyToAdd
		[
			{ ResourceType=antimatter;              RandomWeight=19;  RandomQuantity=[50%, 100%]; }
			{ ResourceType=dilithium;           	RandomWeight=2;  RandomQuantity=[20%, 40%]; }
			{ ResourceType=torpedo_part;   			RandomWeight=20;  RandomQuantity=[75%, 100%]; }
			{ ResourceType=transphasic_torpedo_part;   			RandomWeight=3;  RandomQuantity=[10%, 25%]; }
		]
	}
	//******************** Asteroids ********************
	{
		Action = AddMany
		AddTo = "<./Data/ships/asteroid/asteroid.rules>/Asteroid/Parts"
		ManyToAdd
		[
			&<asteroids/deposit_dilithium/deposit_dilithium_1x.rules>/Part
			//&<asteroids/deposit_dilithium/deposit_dilithium_1x_hard.rules>/Part
			&<asteroids/deposit_dilithium/deposit_dilithium_2x.rules>/Part
			//&<asteroids/deposit_dilithium/deposit_dilithium_2x_hard.rules>/Part
			&<asteroids/deposit_dilithium/deposit_dilithium_3x.rules>/Part
			//&<asteroids/deposit_dilithium/deposit_dilithium_3x_hard.rules>/Part
		]
	}
	{
		Action = AddMany
		AddTo = "<./Data/modes/career/sectors/sysgen_asteroids.rules>/CommonAsteroidTypes"
		ManyToAdd
		[
			{ Type=stafa.asteroid_dilithium_s;     ChanceWeight=1/16; }
			{ Type=stafa.asteroid_dilithium_m;     ChanceWeight=1/32; }
			{ Type=stafa.asteroid_dilithium_l;     ChanceWeight=1/64; }
		]
	}
	{
		Action = AddMany
		AddTo = "<./Data/modes/career/sectors/sysgen_asteroids.rules>/RareAsteroidTypes"
		ManyToAdd
		[
			{ Type=stafa.asteroid_dilithium_xl;     ChanceWeight=1/2; }
			{ Type=stafa.asteroid_dilithium_xxl;     ChanceWeight=1/2; }
		]
	}
	{
		Action = AddMany
		AddTo = "<./Data/modes/career/sectors/sysgen_suns.rules>/SunAsteroidTypes"
		ManyToAdd
		[
			{ Type=stafa.asteroid_dilithium_l;     ChanceWeight=1; }
			{ Type=stafa.asteroid_dilithium_xl;     ChanceWeight=1/2; }
			{ Type=stafa.asteroid_dilithium_xxl;     ChanceWeight=1/4; }
		]
	}
	//******************** UI ********************
	{
		Action = AddMany
		AddTo = "<./Data/gui/game/parts/part_stats.rules>/PartStats"
		ManyToAdd
		[
			{
				ID = AntimatterCapacity
				FormatKey = "Stats/AntimatterCapacityFmt"
			}
		]
	}
